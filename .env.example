# =====================================================================
# AradhyeMusic — Environment Configuration
# Copy this file to `.env` and fill in your own values.
# Never commit your real .env to Git.
# =====================================================================

# ----- Telegram core (REQUIRED) ----------------------------------------------
API_ID=
API_HASH=
BOT_TOKEN=
STRING_SESSION=

# ----- Owner / admin (REQUIRED) ----------------------------------------------
OWNER_ID=
OWNER_USERNAME=
BOT_USERNAME=

# ----- Database (REQUIRED) ---------------------------------------------------
MONGO_DB_URI=

# ----- Logging (REQUIRED) ----------------------------------------------------
# Group ID where the bot will post logs. Bot must be admin in this group.
LOG_GROUP_ID=

# ----- Extra assistant string sessions (optional, up to 5) -------------------
STRING_SESSION2=
STRING_SESSION3=
STRING_SESSION4=
STRING_SESSION5=

# ----- Spotify (optional) ----------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ----- Heroku (optional, only if deploying on Heroku) ------------------------
HEROKU_APP_NAME=
HEROKU_API_KEY=

# ----- Upstream / updates (optional) -----------------------------------------
UPSTREAM_REPO=https://github.com/amanraj1240/AradhyeMusic
UPSTREAM_BRANCH=main
GIT_TOKEN=

# ----- Branding & support links (optional) -----------------------------------
SUPPORT_CHANNEL=https://t.me/ShrutiBots
SUPPORT_GROUP=https://t.me/ShrutiBotsSupport
INSTAGRAM=https://instagram.com/
YOUTUBE=https://youtube.com/
GITHUB=https://github.com/amanraj1240
DONATE=
PRIVACY_LINK=https://graph.org/Privacy-Policy-05-01-30

# ----- Limits (optional) -----------------------------------------------------
DURATION_LIMIT=300
PLAYLIST_FETCH_LIMIT=25
TG_AUDIO_FILESIZE_LIMIT=104857600
TG_VIDEO_FILESIZE_LIMIT=2145386496
AUTO_LEAVING_ASSISTANT=False

# ----- Start image (optional) -----------------------------------------------
START_IMG_URL=https://files.catbox.moe/7q8bfg.jpg
